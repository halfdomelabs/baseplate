{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "prisma:generate", "gql:generate"],
      "inputs": ["$TURBO_DEFAULT$", "!README.md", "!**/*.test.ts"],
      "outputs": ["build/**", "dist/**", ".next/**", "!.next/cache/**"],
      "persistent": false
    },
    "dev": { "cache": false, "persistent": true },
    "gql:generate": {
      "inputs": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "codegen.ts",
        "$TURBO_ROOT$/apps/backend/schema.graphql"
      ],
      "outputs": ["src/gql/**"]
    },
    "gql:watch": { "cache": false, "persistent": true },
    "lint": { "dependsOn": ["^build", "prisma:generate", "gql:generate"] },
    "prettier:check": {},
    "prettier:check:root": {},
    "prettier:write": { "cache": false },
    "prettier:write:root": { "cache": false },
    "prisma:generate": {
      "inputs": ["prisma/schema.prisma"],
      "outputs": ["src/generated/prisma/**"]
    },
    "test": { "dependsOn": ["^build", "prisma:generate", "gql:generate"] },
    "typecheck": { "dependsOn": ["prisma:generate", "gql:generate"] },
    "watch": { "cache": false, "persistent": true }
  }
}
