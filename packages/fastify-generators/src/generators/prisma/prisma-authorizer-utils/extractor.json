{
  "name": "prisma/prisma-authorizer-utils",
  "extractors": {
    "ts": {
      "importProviders": [
        "@baseplate-dev/fastify-generators:authorizerUtilsImportsProvider"
      ]
    }
  },
  "templates": {
    "utils-authorizers": {
      "type": "ts",
      "fileOptions": { "kind": "singleton" },
      "group": "main",
      "importMapProviders": {
        "authRolesImportsProvider": {
          "importName": "authRolesImportsProvider",
          "packagePathSpecifier": "@baseplate-dev/fastify-generators:src/generators/auth/auth-roles/generated/ts-import-providers.ts"
        },
        "dataUtilsImportsProvider": {
          "importName": "dataUtilsImportsProvider",
          "packagePathSpecifier": "@baseplate-dev/fastify-generators:src/generators/prisma/data-utils/generated/ts-import-providers.ts"
        },
        "errorHandlerServiceImportsProvider": {
          "importName": "errorHandlerServiceImportsProvider",
          "packagePathSpecifier": "@baseplate-dev/fastify-generators:src/generators/core/error-handler-service/generated/ts-import-providers.ts"
        },
        "prismaGeneratedImportsProvider": {
          "importName": "prismaGeneratedImportsProvider",
          "packagePathSpecifier": "@baseplate-dev/fastify-generators:src/generators/prisma/_providers/prisma-generated-imports.ts"
        },
        "prismaQueryFilterUtilsImportsProvider": {
          "importName": "prismaQueryFilterUtilsImportsProvider",
          "packagePathSpecifier": "@baseplate-dev/fastify-generators:src/generators/prisma/prisma-query-filter-utils/generated/ts-import-providers.ts"
        },
        "serviceContextImportsProvider": {
          "importName": "serviceContextImportsProvider",
          "packagePathSpecifier": "@baseplate-dev/fastify-generators:src/generators/core/service-context/generated/ts-import-providers.ts"
        }
      },
      "pathRootRelativePath": "{src-root}/utils/authorizers.ts",
      "projectExports": {
        "ActionGrant": { "isTypeOnly": true, "name": "ActionGrant" },
        "ActionMembers": { "isTypeOnly": true, "name": "ActionMembers" },
        "cachedSet": { "isTypeOnly": false, "name": "cachedSet" },
        "checkGlobalAuthorization": {
          "isTypeOnly": false,
          "name": "checkGlobalAuthorization"
        },
        "checkInstanceAuthorization": {
          "isTypeOnly": false,
          "name": "checkInstanceAuthorization"
        },
        "createModelPolicy": {
          "isTypeOnly": false,
          "name": "createModelPolicy"
        },
        "GlobalRoleCheck": { "isTypeOnly": true, "name": "GlobalRoleCheck" },
        "InstanceRoleCheck": {
          "isTypeOnly": true,
          "name": "InstanceRoleCheck"
        },
        "PolicyRoleMembers": {
          "isTypeOnly": true,
          "name": "PolicyRoleMembers"
        },
        "RoleBuilder": { "isTypeOnly": true, "name": "RoleBuilder" }
      },
      "sourceFile": "src/utils/authorizers.ts",
      "variables": {}
    }
  }
}
