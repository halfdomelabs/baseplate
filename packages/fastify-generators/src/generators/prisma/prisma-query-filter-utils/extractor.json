{
  "name": "prisma/prisma-query-filter-utils",
  "templates": {
    "utils-query-helpers": {
      "type": "ts",
      "fileOptions": { "kind": "singleton" },
      "group": "main-group",
      "importMapProviders": {
        "dataUtilsImportsProvider": {
          "importName": "dataUtilsImportsProvider",
          "packagePathSpecifier": "@baseplate-dev/fastify-generators:src/generators/prisma/data-utils/generated/ts-import-providers.ts"
        }
      },
      "pathRootRelativePath": "{src-root}/utils/query-helpers.ts",
      "projectExports": {
        "queryHelpers": { "isTypeOnly": false, "name": "queryHelpers" },
        "WhereResult": { "isTypeOnly": true, "name": "WhereResult" }
      },
      "sourceFile": "src/utils/query-helpers.ts",
      "variables": {}
    }
  }
}
