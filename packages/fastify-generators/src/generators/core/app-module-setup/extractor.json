{
  "name": "core/app-module-setup",
  "templates": {
    "app-modules": {
      "type": "ts",
      "fileOptions": { "kind": "singleton" },
      "generator": "@baseplate-dev/fastify-generators#core/app-module-setup",
      "importMapProviders": {
        "appRuntimeImportsProvider": {
          "importName": "appRuntimeImportsProvider",
          "packagePathSpecifier": "@baseplate-dev/fastify-generators:src/generators/core/app-runtime/generated/ts-import-providers.ts"
        }
      },
      "pathRootRelativePath": "{src-root}/utils/app-modules.ts",
      "projectExports": {
        "AppPlugin": { "isTypeOnly": true },
        "defineAppModule": {},
        "flattenAppModule": {},
        "PluginRuntime": { "isTypeOnly": true },
        "PluginRuntimeWithServices": { "isTypeOnly": true }
      },
      "sourceFile": "src/utils/app-modules.ts",
      "variables": {
        "TPL_MODULE_FIELDS": {},
        "TPL_MODULE_INITIALIZER": {},
        "TPL_MODULE_MERGER": {}
      }
    }
  }
}
