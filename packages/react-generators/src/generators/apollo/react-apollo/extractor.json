{
  "name": "apollo/react-apollo",
  "extractors": {
    "ts": {
      "importProviders": [
        "@baseplate-dev/react-generators:graphqlImportsProvider"
      ]
    }
  },
  "templates": {
    "app-apollo-provider": {
      "type": "ts",
      "fileOptions": { "kind": "singleton" },
      "generator": "@baseplate-dev/react-generators#apollo/react-apollo",
      "group": "main",
      "importMapProviders": {},
      "pathRootRelativePath": "{src-root}/app/app-apollo-provider.tsx",
      "referencedGeneratorTemplates": ["service"],
      "sourceFile": "src/app/app-apollo-provider.tsx",
      "variables": {
        "TPL_CREATE_ARGS": {},
        "TPL_MEMO_DEPENDENCIES": {},
        "TPL_RENDER_BODY": {}
      }
    },
    "cache": {
      "type": "ts",
      "fileOptions": { "kind": "singleton" },
      "generator": "@baseplate-dev/react-generators#apollo/react-apollo",
      "group": "main",
      "importMapProviders": {},
      "pathRootRelativePath": "{src-root}/services/apollo/cache.ts",
      "projectExports": { "createApolloCache": {} },
      "sourceFile": "src/services/apollo/cache.ts",
      "variables": {}
    },
    "codegen": {
      "type": "ts",
      "fileOptions": { "kind": "singleton" },
      "generator": "@baseplate-dev/react-generators#apollo/react-apollo",
      "group": "main",
      "importMapProviders": {},
      "pathRootRelativePath": "{package-root}/codegen.ts",
      "sourceFile": "package/codegen.ts",
      "variables": { "TPL_BACKEND_SCHEMA_PATH": {}, "TPL_SCALARS": {} }
    },
    "gql-fragment-masking": {
      "type": "ts",
      "fileOptions": { "kind": "singleton" },
      "group": "main",
      "importMapProviders": {},
      "pathRootRelativePath": "{src-root}/gql/fragment-masking.ts",
      "projectExports": {
        "FragmentType": { "isTypeOnly": true },
        "readFragment": {}
      },
      "projectExportsOnly": true,
      "sourceFile": "src/gql/fragment-masking.ts",
      "variables": {}
    },
    "gql-gql": {
      "type": "ts",
      "fileOptions": { "kind": "singleton" },
      "group": "main",
      "importMapProviders": {},
      "pathRootRelativePath": "{src-root}/gql/gql.ts",
      "projectExports": { "graphql": {} },
      "projectExportsOnly": true,
      "sourceFile": "src/gql/gql.ts",
      "variables": {}
    },
    "gql-graphql": {
      "type": "ts",
      "fileOptions": { "kind": "singleton" },
      "group": "main",
      "importMapProviders": {},
      "pathRootRelativePath": "{src-root}/gql/graphql.ts",
      "projectExports": { "*": {} },
      "projectExportsOnly": true,
      "sourceFile": "src/gql/graphql.ts",
      "variables": {}
    },
    "graphql-config": {
      "type": "ts",
      "fileOptions": { "kind": "singleton" },
      "group": "main",
      "importMapProviders": {},
      "pathRootRelativePath": "{package-root}/graphql.config.ts",
      "sourceFile": "package/graphql.config.ts",
      "variables": { "TPL_BACKEND_SCHEMA_PATH": {} }
    },
    "service": {
      "type": "ts",
      "fileOptions": { "kind": "singleton" },
      "generator": "@baseplate-dev/react-generators#apollo/react-apollo",
      "group": "main",
      "importMapProviders": {},
      "pathRootRelativePath": "{src-root}/services/apollo/index.ts",
      "projectExports": { "createApolloClient": {} },
      "referencedGeneratorTemplates": ["cache"],
      "sourceFile": "src/services/apollo/index.ts",
      "variables": {
        "TPL_CREATE_ARGS": {},
        "TPL_LINK_BODIES": {},
        "TPL_LINKS": {}
      }
    },
    "websocket-links": {
      "type": "ts-snippet",
      "sourceFile": "websocket-links.ts"
    }
  }
}
